# ──────────────────────────────────────────────────────────────
#  .env.example — Copie ce fichier en .env et complète les valeurs
#  cp .env.example .env
#
#  ⚠️  Ne jamais committer .env sur Git
# ──────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=MotDePasseFort_changez_moi
POSTGRES_DB=sante_integree

# ── Backend ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:MotDePasseFort_changez_moi@postgres:5432/sante_integree

# Génère une clé sécurisée :
#   python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=changez-moi-avec-une-cle-aleatoire-de-64-chars-minimum

ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# Mots de passe des comptes créés au premier démarrage
ADMIN_PASSWORD=Admin1234!
AGENT_PASSWORD=Agent1234!

# ── Frontend ────────────────────────────────────────────────
# En production avec Docker+Nginx : /api
# En développement direct : http://localhost:8000
VITE_API_URL=/api

# ── DHIS2 ───────────────────────────────────────────────────
DHIS2_URL=http://dhis2:8080
DHIS2_USERNAME=admin
DHIS2_PASSWORD=district
